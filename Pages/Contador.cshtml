@page
@model ProjetoTypescriptMvc.Pages.ContadorModel
@{
    ViewData["Title"] = "Contador";
}

<div class="container py-4">
    <h1 class="display-6">Contador com TypeScript</h1>
    <p class="text-muted">Clique no botao para incrementar o valor.</p>

    <div class="d-flex align-items-center gap-3">
        <button id="incrementarBtn" type="button" class="btn btn-primary">Incrementar</button>
        <button id="resetarBtn" type="button" class="btn btn-outline-secondary">Resetar</button>
        <span id="valorContador" class="fs-4 fw-bold">0</span>
    </div>
</div>

@section Scripts {
    <script src="~/js/contador.js" asp-append-version="true"></script>
}
