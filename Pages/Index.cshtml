@page
@model IndexModel
@{
    ViewData["Title"] = "TypeScript Playground";
}

<div class="container py-4">
    <h1 class="display-5">Treino de TypeScript no ASP.NET</h1>
    <p class="text-muted">Digite um nome e clique no botao para testar classe, tipos e manipulacao de evento.</p>

    <div class="row g-2 align-items-center mt-3">
        <div class="col-sm-8">
            <input id="nomeInput" class="form-control" type="text" placeholder="Digite seu nome" />
        </div>
        <div class="col-sm-4">
            <button id="saudarBtn" class="btn btn-primary w-100" type="button">Saudar</button>
        </div>
    </div>

    <p id="mensagem" class="mt-3 fw-semibold"></p>
</div>
